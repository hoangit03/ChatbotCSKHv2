APP_ENV=development
APP_SECRET_KEY=change-me-must-be-at-least-32-characters!!
APP_PORT=8005
DEBUG=false

# ── LLM Provider (swap không cần đổi code — chỉ đổi .env + restart)
LLM_PROVIDER=anthropic           # anthropic | openai | gemini | ollama | qwen
LLM_MODEL=claude-opus-4-5
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # GPT / Gemini / Ollama
# GOOGLE_API_KEY=AIza...
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama

# ── Embedding (bắt buộc dù dùng LLM provider nào)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Vector DB (Qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=my-super-secret-key
QDRANT_COLLECTION=realestate_kb

# ── PostgreSQL
DB_USER=raguser
DB_PASSWORD=ragpassword
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@postgres:5432/ragdb

# ── Redis
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@redis:6379/0
CACHE_TTL=3600

# ── Sales Backend API (key gửi qua header X-Internal-Key, không qua URL)
SALES_API_BASE_URL=https://sales-backend.internal.company.com
SALES_API_KEY=internal-service-secret-key-change-me
SALES_API_TIMEOUT=10
SALES_API_MAX_RETRIES=3

# ── File Storage
STORAGE_PATH=./storage/documents
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,xlsx,png,jpg,jpeg

# ── Chunking
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# ── Rate Limiting
RATE_LIMIT_CHAT=30               # requests/minute per IP
RATE_LIMIT_UPLOAD=20             # requests/hour per IP

# ── Agent (LangGraph)
AGENT_MAX_ITERATIONS=8
RAG_SCORE_THRESHOLD=0.70
QA_SCORE_THRESHOLD=0.45